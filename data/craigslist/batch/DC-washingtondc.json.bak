        "price": 1341,
        "price_text": "$1,341",
        "room": 1,
        "area": "566",
        "loft": "1",
        "location": "2001 Southhampton St near Pine Lane",
        "full_address": "2001 Southhampton St near Pine Lane",
        "locality": "",
