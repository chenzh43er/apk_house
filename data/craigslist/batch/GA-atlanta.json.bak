      "craigslist": {
        "url": "https://atlanta.craigslist.org/sat/apa/d/atlanta-newly-upgraded-move-in-ready/7945101851.html",
        "posting_id": "7945101851",
        "title": "Newly upgraded! Move in ready! Don't miss out!",
        "price": 838,
        "price_text": "$838",
        "room": 1,
        "area": "600",
        "loft": "1",
        "location": "2210 Sullivan Road",
        "full_address": "2210 Sullivan Road, College Park, GA 30337",
        "locality": "College Park",
