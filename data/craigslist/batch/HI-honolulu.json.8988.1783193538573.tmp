        "title": "TMLP 12-mo. | Luxurious 2 BR/2 BA Retreat with Private Lanai",
        "price": 3967,
        "price_text": "$3,967",
        "room": 2,
        "area": "1057",
        "loft": "1",
        "location": "00PM The Element 91-3598 Nana Hope Street",
