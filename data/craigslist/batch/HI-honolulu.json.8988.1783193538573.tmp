        "url": "https://honolulu.craigslist.org/oah/apa/d/kapolei-tmlp-15-mo-self-service-pet-spa/7945017863.html",
        "posting_id": "7945017863",
        "title": "TMLP 15-mo. | Self-Service Pet Spa, ADA Modified Units Available",
        "price": 3654,
        "price_text": "$3,654",
        "room": 2,
