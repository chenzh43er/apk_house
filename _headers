/Public/Js/ad-loader.js
  Cache-Control: public, max-age=0, must-revalidate

/Public/Js/ad-runtime.js
  Cache-Control: public, max-age=0, must-revalidate

/Public/Js/ad-oop.js
  Cache-Control: public, max-age=0, must-revalidate

/Public/Js/ad-slots-adx.js
  Cache-Control: public, max-age=0, must-revalidate

/Public/Css/ad-mobile.css
  Cache-Control: public, max-age=0, must-revalidate

/Public/Css/form-page.css
  Cache-Control: public, max-age=0, must-revalidate

/Public/Css/state-page.css
  Cache-Control: public, max-age=0, must-revalidate

/Public/Css/list-page.css
  Cache-Control: public, max-age=0, must-revalidate

/Public/Fonts/*
  Cache-Control: public, max-age=31536000, immutable

/Public/svg/*
  Cache-Control: public, max-age=31536000, immutable

