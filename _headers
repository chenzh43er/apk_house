/Public/Css/*
  Cache-Control: public, max-age=31536000, immutable

/Public/Js/*
  Cache-Control: public, max-age=31536000, immutable

# 广告层配置会频繁调整，勿长期 immutable 缓存
/Public/Js/ad-config.js
