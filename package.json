{
  "name": "apk_house",
  "private": true,
  "scripts": {
    "predev": "npx --yes kill-port 8787",
    "dev": "wrangler pages dev . --port 8787",
    "dev:static": "npx --yes serve -l 8788 .",
    "check": "wrangler check",
    "deploy:worker": "wrangler deploy",
    "deploy:pages": "wrangler pages deploy . --project-name=apk-house --branch=main",
    "deploy": "npm run deploy:pages && npm run deploy:worker",
    "tail": "wrangler tail billowing-leaf-30ae",
    "whoami": "wrangler whoami"
  },
  "devDependencies": {
    "wrangler": "^4.98.0"
  }
}
