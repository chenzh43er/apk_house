{
  "name": "apk_house",
  "private": true,
  "scripts": {
    "predev": "node scripts/kill-port.mjs 8787",
    "dev": "wrangler pages dev . --port 8787",
    "dev:static": "npx --yes serve -l 8788 .",
    "check": "wrangler check",
    "deploy:worker": "wrangler deploy --config wrangler.worker.toml",
    "deploy:pages": "wrangler pages deploy . --project-name=apk-house --branch=main",
    "deploy": "npm run deploy:pages && npm run deploy:worker",
    "inline-layout": "node scripts/inline-header-footer.mjs",
    "optimize-assets": "node scripts/optimize-assets.mjs",
    "tail": "wrangler tail billowing-leaf-30ae --config wrangler.worker.toml",
    "whoami": "wrangler whoami",
    "cf:security": "node scripts/cloudflare-security-setup.mjs",
    "cf:security:dry-run": "node scripts/cloudflare-security-setup.mjs --dry-run",
    "cf:ads-bypass": "node scripts/cloudflare-ads-txt-bypass.mjs",
    "cf:ads-bypass:dry-run": "node scripts/cloudflare-ads-txt-bypass.mjs --dry-run",
    "cf:apply-ads-fix": "node scripts/cloudflare-apply-ads-fix.mjs",
    "cf:static-bypass": "node scripts/cloudflare-static-bot-bypass.mjs",
    "cf:static-bypass:dry-run": "node scripts/cloudflare-static-bot-bypass.mjs --dry-run",
    "gam:networks": "node scripts/ad-manager/list-networks.mjs",
    "gam:check": "node scripts/ad-manager/check-network.mjs",
    "gam:probe": "node scripts/ad-manager/probe-proxy.mjs",
    "gam:checklist": "node scripts/ad-manager/generate-checklist.mjs",
    "gam:create-units": "node scripts/ad-manager/create-ad-units.mjs",
    "gam:create-units:dry-run": "node scripts/ad-manager/create-ad-units.mjs --dry-run",
    "craigslist:scrape": "node scripts/craigslist/scrape.mjs",
    "craigslist:batch-us": "node scripts/craigslist/batch-us.mjs",
    "craigslist:merge-us": "node scripts/craigslist/batch-us.mjs --merge-only",
    "craigslist:import": "node scripts/craigslist/import.mjs",
    "craigslist:upload-images": "node scripts/craigslist/upload-images.mjs"
  },
  "devDependencies": {
    "pg": "^8.22.0",
    "playwright": "^1.61.1",
    "wrangler": "^4.98.0"
  }
}
